{
	"compilerOptions": {
		"module": "esnext",
		"target": "esnext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"resolveJsonModule": true,
		"verbatimModuleSyntax": true,
		"jsx": "preserve",
		"lib": ["esnext", "dom", "dom.iterable"],
		"paths": {
			"~/*": ["./src/*"],
			"~vitepress/*": ["./.vitepress/*"]
		}
	},
	"exclude": ["node_modules"],
	"include": [
		"env.d.ts",
		"src/**/*.ts",
		"src/**/*.vue",
		".vitepress/**/*.ts",
		".vitepress/**/*.vue"
	]
}